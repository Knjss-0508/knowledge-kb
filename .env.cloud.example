# 云部署示例：复制为 .env 后替换所有占位值。
DEPLOY_DATABASE_MODE=cloud

# 必须是 PostgreSQL 16 或兼容版本，并已允许 vector 扩展。
# 托管数据库通常需要 sslmode=require。
# 用户名或密码中的 @ / : # % 等字符必须先做 URL 百分号编码。
DATABASE_URL=postgresql://db_user:replace-with-db-password@db.example.com:5432/knowledge_base?sslmode=require
DB_CONNECT_RETRIES=60
DB_CONNECT_RETRY_SECONDS=2
DB_CONNECT_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800

INITIAL_ADMIN_USERNAME=knowledge-admin
INITIAL_ADMIN_PASSWORD=replace-with-at-least-12-characters
INITIAL_ADMIN_FORCE_RESET=false
ALLOW_INSECURE_DEFAULT_ADMIN=false

BACKEND_PORT=8000
# 默认只允许同机反向代理访问。直接暴露公网时需改为 0.0.0.0，
# 并同时配置防火墙、HTTPS 和应用层访问控制。
HOST_BIND_IP=127.0.0.1
REDIS_PORT=6379
SESSION_TTL_HOURS=24

NMHT_BASE_URL=https://nmht.zhuanspirit.com
NMHT_COOKIE=
# 云部署必须替换为至少 24 位的随机服务密钥，不能保留占位值。
INTEGRATION_API_KEY=replace-with-a-strong-secret

EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=http://embedding-qwen:80/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_DIMENSIONS=1024
EMBEDDING_HEALTHCHECK_URL=
EMBEDDING_CPU_THREADS=0
EMBEDDING_CPU_BATCH_SIZE=8

DEPLOY_RUNTIME=auto
DEPLOY_TIMEOUT_SECONDS=900
TEI_GPU_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cuda-1.8.3
TEI_GPU_LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libcuda.so.1

DEDUP_BLOCK_THRESHOLD=0.96
DEDUP_REVIEW_THRESHOLD=0.88
DEDUP_MAX_CANDIDATES=10
DEDUP_MIN_SEMANTIC_CONTENT_CHARS=8
DEDUP_MIN_CONTAINMENT_CONTENT_CHARS=12
SEARCH_CHUNK_SIZE=800
SEARCH_CHUNK_OVERLAP=120
UPLOAD_MAX_BYTES=20971520

MEDIA_STORAGE_BACKEND=s3
S3_BUCKET=replace-with-bucket-name
# AWS S3 留空；MinIO、R2、COS 等 S3 兼容服务填写 HTTPS endpoint。
S3_ENDPOINT_URL=
S3_REGION=us-east-1
# 在支持实例角色/工作负载身份的环境中可以留空固定密钥。
# 若填写固定凭据，Access Key 和 Secret Key 必须同时填写。
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_KEY_PREFIX=knowledge-kb/prod/media
S3_ADDRESSING_STYLE=auto
S3_PUBLIC_BASE_URL=
S3_PRESIGN_EXPIRES_SECONDS=900
# 对象上传中的数据库租约；上传期间持有行锁，进程崩溃后按此时间回收。
MEDIA_UPLOAD_ACTIVE_TTL_SECONDS=3600
# 临时媒体在对象存储中等待知识保存的有效期。
MEDIA_UPLOAD_STAGING_TTL_SECONDS=900
