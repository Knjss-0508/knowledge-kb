# Copy this file to .env. Do not commit or paste real API keys into Excel, browser code, or logs.
# Use the OpenAI-compatible base URL and model ID supplied by the MiMo console.
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_TIMEOUT_SECONDS=60
ANSWER_HUB_DB_PATH=data/answer_hub.db

# Optional product taxonomy override. Empty uses the packaged ten-category default.
ANSWER_HUB_PRODUCT_TAXONOMY_PATH=

# OpenAI-compatible embedding service used by semantic topic clustering.
EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=120
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_RETRIES=3
EMBEDDING_BATCH_CHAR_LIMIT=1600
EMBEDDING_MAX_TEXT_CHARS=1600
EMBEDDING_CACHE_SIZE=5000

# CZ knowledge-base integration. Keep the key server-side only.
KB_BASE_URL=
KB_INTEGRATION_KEY=
KB_TIMEOUT_SECONDS=30
KB_MAX_RETRIES=3
KB_RETRY_BACKOFF_SECONDS=0.5

# Model auto-review rollout. Keep disabled while teammates create validation gold labels.
AUTO_REVIEW_ENABLED=false
AUTO_REVIEW_MIN_CONFIDENCE=0.85
AUTO_REVIEW_MIN_VALIDATION_SAMPLES=40
AUTO_REVIEW_MIN_VALIDATION_ACCURACY=0.90
AUTO_REVIEW_MIN_PASS_PRECISION=0.95
# Fill these only after the exact model and prompt version pass validation.
AUTO_REVIEW_VALIDATED_MODEL=
AUTO_REVIEW_VALIDATED_PROMPT_VERSION=

# Transfer-to-human analysis. Browser cookies remain in Playwright's local
# persistent browser profile and must never be copied into this file.
TRANSFER_ANALYSIS_DB_PATH=data/transfer_analysis.db
TRANSFER_MANHATTAN_PROFILE=
TRANSFER_BAIXIAOSHENG_PROFILE=
TRANSFER_KB_CATALOG_PATH=
