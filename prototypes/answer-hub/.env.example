# Copy this file to .env. Do not commit or paste real API keys into Excel, browser code, or logs.
# Use the OpenAI-compatible base URL and model ID supplied by the MiMo console.
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
# Full-modal model used when clustering rows contain image or video links.
MIMO_MEDIA_MODEL=mimo-v2.5
MIMO_TIMEOUT_SECONDS=60
MIMO_MAX_RETRIES=2
MIMO_RETRY_BACKOFF_SECONDS=0.75
MIMO_MAX_REQUESTS_PER_SECOND=2
# Optional pricing used only for local cost estimation.
MIMO_INPUT_COST_PER_MILLION_TOKENS=0
MIMO_OUTPUT_COST_PER_MILLION_TOKENS=0
ANSWER_HUB_DB_PATH=data/answer_hub.db

# Runtime operations, SLA and retention.
ANSWER_HUB_MIMO_MAX_WORKERS=1
ANSWER_HUB_REDACTION_ENFORCE=true
ANSWER_HUB_SLA_SECONDS_PER_100_ROWS=3600
ANSWER_HUB_SLA_MAX_FAILURE_RATE=0.05
ANSWER_HUB_SLA_MAX_FALLBACK_RATE=0.20
ANSWER_HUB_MAX_RUN_COST=50
ANSWER_HUB_RETENTION_DAYS=30

# Optional product taxonomy override. Empty uses the packaged ten-category default.
ANSWER_HUB_PRODUCT_TAXONOMY_PATH=

# OpenAI-compatible embedding service used by semantic topic clustering.
EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=120
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_RETRIES=3
EMBEDDING_BATCH_CHAR_LIMIT=1600
EMBEDDING_MAX_TEXT_CHARS=1600
EMBEDDING_CACHE_SIZE=5000

# CZ knowledge-base integration. Keep the key server-side only.
KB_BASE_URL=
KB_INTEGRATION_KEY=
KB_TIMEOUT_SECONDS=30
KB_MAX_RETRIES=3
KB_RETRY_BACKOFF_SECONDS=0.5

# Model auto-review rollout. Keep disabled while teammates create validation gold labels.
AUTO_REVIEW_ENABLED=false
AUTO_REVIEW_KILL_SWITCH=false
# Comma-separated product names. Empty means all validated products only after explicit enablement.
AUTO_REVIEW_PRODUCT_TYPES=
AUTO_REVIEW_MIN_CONFIDENCE=0.85
AUTO_REVIEW_MIN_VALIDATION_SAMPLES=40
AUTO_REVIEW_MIN_VALIDATION_ACCURACY=0.90
AUTO_REVIEW_MIN_PASS_PRECISION=0.95
# Fill these only after the exact model and prompt version pass validation.
AUTO_REVIEW_VALIDATED_MODEL=
AUTO_REVIEW_VALIDATED_PROMPT_VERSION=

# Unattended workbook automation. Drop .xlsx/.xlsm files into the pending folder.
# Rule mode is the safe default and does not require model credentials.
ANSWER_HUB_AUTOMATION_QUEUE=data/automation-queue
ANSWER_HUB_AUTOMATION_OUTPUT=outputs/automation-runs
ANSWER_HUB_AUTOMATION_STANDARDS=
ANSWER_HUB_AUTOMATION_PRODUCT_TYPE=
ANSWER_HUB_AUTOMATION_USE_MIMO=false
ANSWER_HUB_AUTOMATION_CLUSTERING_MODE=rule
# Sync every model-reviewed topic to CZ candidate value review. This does not
# create or publish knowledge; CZ reviewers must click batch submit afterward.
ANSWER_HUB_AUTOMATION_SYNC_TO_CZ_REVIEW=false
# Deprecated compatibility alias. Used only when the new variable is empty.
ANSWER_HUB_AUTOMATION_SUBMIT_TO_CZ=false
ANSWER_HUB_AUTOMATION_MAX_FILES=10
ANSWER_HUB_AUTOMATION_STALE_AFTER_SECONDS=7200

# Dify calls this API through http://host.docker.internal:8780.
# Generate a long random value locally; never commit the real key.
ANSWER_HUB_API_KEY=
ANSWER_HUB_API_HOST=0.0.0.0
ANSWER_HUB_API_PORT=8780

# Transfer-to-human analysis. Browser cookies remain in Playwright's local
# persistent browser profile and must never be copied into this file.
TRANSFER_ANALYSIS_DB_PATH=data/transfer_analysis.db
TRANSFER_MANHATTAN_PROFILE=
TRANSFER_BAIXIAOSHENG_PROFILE=
TRANSFER_KB_CATALOG_PATH=
