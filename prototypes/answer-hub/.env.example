# Copy this file to .env. Do not commit or paste real API keys into Excel, browser code, or logs.
# Use the OpenAI-compatible base URL and model ID supplied by the MiMo console.
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_TIMEOUT_SECONDS=60
ANSWER_HUB_DB_PATH=data/phone_mvp.db

# OpenAI-compatible embedding service used by semantic topic clustering.
EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=30

# Reserved for the future cz knowledge-base integration. The current phone pilot
# only displays readiness and validates local payloads; it does not send requests.
KB_BASE_URL=
KB_INTEGRATION_KEY=
