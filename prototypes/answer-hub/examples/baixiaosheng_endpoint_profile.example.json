{
  "system": "baixiaosheng",
  "base_url": "https://replace-with-actual-host",
  "login_url": "https://replace-with-actual-login-page",
  "profile_dir": "data/browser_profiles/baixiaosheng",
  "channel": "chrome",
  "operations": {
    "lookup": {
      "method": "POST",
      "path": "<fill-from-network-discovery>",
      "body": {
        "<work-order-field>": "{{work_order_id}}",
        "<page-field>": "{{page}}",
        "<page-size-field>": "{{page_size}}"
      },
      "items_path": "<response-path-to-session-array>",
      "total_path": "<response-path-to-total>",
      "page_size": 100,
      "field_map": {
        "source_id": "<path-to-session-id>",
        "conversation_id": "<path-to-session-id>",
        "work_order_id": "<path-to-work-order-id>",
        "engineer": "<path-to-engineer>",
        "started_at": "<path-to-start-time>",
        "ended_at": "<path-to-end-time>"
      }
    },
    "detail": {
      "method": "POST",
      "path": "<fill-from-network-discovery>",
      "body": {
        "<session-id-field>": "{{source_id}}"
      },
      "record_path": "<response-path-to-detail>",
      "field_map": {
        "source_id": "<path-to-session-id>",
        "work_order_id": "<path-to-work-order-id>",
        "engineer": "<path-to-engineer>",
        "started_at": "<path-to-start-time>",
        "ended_at": "<path-to-end-time>",
        "first_question": "<path-to-first-question>",
        "last_answer": "<path-to-last-answer>",
        "intent_result": "<path-to-intent-result>",
        "conversation_text": "<path-to-conversation-text>",
        "messages": "<path-to-message-array>",
        "retrievals": "<path-to-retrieval-array>",
        "tools": "<path-to-tool-call-array>",
        "attachments": "<path-to-attachment-array>"
      }
    }
  }
}
