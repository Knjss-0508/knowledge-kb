# auto: DATABASE_URL 有值时使用云数据库，否则加载本地 PostgreSQL。
# 生产服务器建议明确设置为 cloud，禁止缺配置时回退本地。
DEPLOY_DATABASE_MODE=auto
# 完整 URL 中的用户名或密码若包含 @ / : # %，必须先做 URL 百分号编码。
DATABASE_URL=
DB_CONNECT_RETRIES=60
DB_CONNECT_RETRY_SECONDS=2
DB_CONNECT_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800

# 仅本地数据库模式使用。
POSTGRES_USER=knowledge_admin
POSTGRES_PASSWORD=knowledge_pass_2026
POSTGRES_DB=knowledge_base
POSTGRES_PORT=5432

BACKEND_PORT=8000
HOST_BIND_IP=127.0.0.1
REDIS_PORT=6379

NMHT_BASE_URL=https://nmht.zhuanspirit.com
NMHT_COOKIE=

# 供自动化链路调用 /api/v1/integration/* 时使用。
INTEGRATION_API_KEY=replace-with-a-strong-secret

# 新空库的初始管理员。云模式必须设置至少 12 位的强密码，并关闭默认弱账号。
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_FORCE_RESET=false
ALLOW_INSECURE_DEFAULT_ADMIN=false

# Qwen3 Embedding service. Switch only the compose override for GPU/CPU servers.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=http://embedding-qwen:80/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_DIMENSIONS=1024
EMBEDDING_HEALTHCHECK_URL=
EMBEDDING_CPU_THREADS=0
EMBEDDING_CPU_BATCH_SIZE=8

# auto: prefer a compatible NVIDIA GPU runtime, otherwise use the Qwen CPU service.
DEPLOY_RUNTIME=auto
DEPLOY_TIMEOUT_SECONDS=900
TEI_GPU_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cuda-1.8.3
TEI_GPU_LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libcuda.so.1

# 语义查重阈值。大于等于 block 时阻止入库，介于 review 和 block 之间时进入人工审核。
DEDUP_BLOCK_THRESHOLD=0.96
DEDUP_REVIEW_THRESHOLD=0.88
DEDUP_MAX_CANDIDATES=10
DEDUP_MIN_SEMANTIC_CONTENT_CHARS=8
DEDUP_MIN_CONTAINMENT_CONTENT_CHARS=12

# 语义检索正文分块参数（中文字符数）
SEARCH_CHUNK_SIZE=800
SEARCH_CHUNK_OVERLAP=120
UPLOAD_MAX_BYTES=20971520
SESSION_TTL_HOURS=24

# 本地部署由 docker-compose.local.yml 强制设置为 local。
# 公共/云 Compose 不提供本地存储默认值，避免误把生产媒体写入容器磁盘。
MEDIA_STORAGE_BACKEND=
UPLOAD_DIR=
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_KEY_PREFIX=knowledge-kb/media
S3_ADDRESSING_STYLE=auto
# 留空时生成私有对象的短时效预签名地址；也可填写 CDN/公开桶根地址。
S3_PUBLIC_BASE_URL=
S3_PRESIGN_EXPIRES_SECONDS=900
# 对象上传中的数据库租约；上传期间持有行锁，进程崩溃后按此时间回收。
MEDIA_UPLOAD_ACTIVE_TTL_SECONDS=3600
# 临时媒体在对象存储中等待知识保存的有效期。
MEDIA_UPLOAD_STAGING_TTL_SECONDS=900
