POSTGRES_USER=knowledge_admin
POSTGRES_PASSWORD=knowledge_pass_2026
POSTGRES_DB=knowledge_base
POSTGRES_PORT=5432

BACKEND_PORT=8000
HOST_BIND_IP=127.0.0.1
ES_PORT=9200
REDIS_PORT=6379

NMHT_BASE_URL=https://nmht.zhuanspirit.com
NMHT_COOKIE=

# 供自动化链路调用 /api/v1/integration/* 时使用。
INTEGRATION_API_KEY=replace-with-a-strong-secret

# Qwen3 Embedding service. Switch only the compose override for GPU/CPU servers.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=http://embedding-qwen:80/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=30

# 语义查重阈值。大于等于 block 时阻止入库，介于 review 和 block 之间时进入人工审核。
DEDUP_BLOCK_THRESHOLD=0.96
DEDUP_REVIEW_THRESHOLD=0.88
DEDUP_MAX_CANDIDATES=10

# 语义检索正文分块参数（中文字符数）
SEARCH_CHUNK_SIZE=800
SEARCH_CHUNK_OVERLAP=120
